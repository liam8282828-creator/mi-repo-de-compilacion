# ═══════════════════════════════════════════════════════════════
#  iOS Cloud Compiler Bot — Variables de entorno
#  Copia este archivo a ".env" y rellena los valores
# ═══════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────
# Obtenlo hablando con @BotFather en Telegram:
#   1. Envía /newbot
#   2. Elige un nombre y un @username
#   3. Copia el token que te da BotFather
TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────────────
# Token de acceso personal (PAT) con permisos:
#   • repo      (acceso completo al repositorio)
#   • workflow  (disparar GitHub Actions)
# Créalo en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tu usuario u organización de GitHub
GITHUB_OWNER=tu-usuario

# El nombre del repositorio donde pusiste el workflow compile.yml
GITHUB_REPO=mi-repo-de-compilacion

# ── Configuración opcional ───────────────────────────────────
# Nombre del archivo de workflow (por defecto: compile.yml)
GITHUB_WORKFLOW_FILE=compile.yml

# Versión del SDK de .NET a instalar en el runner macOS
DOTNET_VERSION=8.0
